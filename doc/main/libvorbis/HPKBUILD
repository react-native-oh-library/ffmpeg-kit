pkgname=libvorbis
pkgver=v1.3.7
pkgrel=0
pkgdesc="Reference implementation of the Ogg Vorbis audio format."
url="https://www.xiph.org/"
archs=("armeabi-v7a" "arm64-v8a")
license=("BSD-3-Clause")
depends=("libogg")
makedepends=()

source="https://github.com/xiph/vorbis/releases/download/$pkgver/$pkgname-${pkgver:1}.tar.gz"

autounpack=true
downloadpackage=true
buildtools="cmake"
builddir=$pkgname-${pkgver:1}
packagename=$builddir.tar.gz

prepare() {
    mkdir -p $builddir/$ARCH-build
}

build() {
    cd $builddir
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" -B$ARCH-build -S./ > $buildlog 2>&1
    $MAKE VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir
    $MAKE -C $ARCH-build install >> $buildlog 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
    # TODO
}

cleanbuild() {
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
}
