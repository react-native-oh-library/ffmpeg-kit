pkgname=libtasn1
pkgver=4.13
pkgrel=0
pkgdesc="libtasn1 is a highly portable C library that encodes and decodes DER/BER data following an ASN.1 schema."
url="https://ftp.gnu.org/gnu/libtasn1"
archs=("armeabi-v7a" "arm64-v8a")
license=("lgpl-2.0")
depends=()
makedepends=()

source="https://ftp.gnu.org/gnu/${pkgname}/${pkgname}-${pkgver}.tar.gz"

downloadpackage=true
autounpack=true
buildtools="configure"

builddir=$pkgname-${pkgver}
packagename=$builddir.tar.gz

source envset.sh
host=

prepare() {
    mkdir -p $builddir/$ARCH-build
    if [ $ARCH == "armeabi-v7a" ]
    then
        setarm32ENV
        host=arm-linux
    elif [ $ARCH == "arm64-v8a" ]
    then
        setarm64ENV
        host=aarch64-linux
    else
        return -1
    fi

    return 0
}

build() {
    cd $builddir/$ARCH-build
    ../configure "$@" --host=$host > $buildlog 2>&1
    $MAKE >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir/$ARCH-build
    $MAKE install >> $buildlog 2>&1
    cd $OLDPWD
    unset host
}

check() {
    if [ $ARCH == "armeabi-v7a" ]
    then
        unsetarm32ENV
    elif [ $ARCH == "arm64-v8a" ]
    then
        unsetarm64ENV
    else
        return -1
    fi

    echo "The test must be on an OpenHarmony device!"

    return 0
}

# 清理环境
cleanbuild(){
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
}
