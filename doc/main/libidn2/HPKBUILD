pkgname=libidn2
pkgver=2.3.0
pkgrel=0
pkgdesc="libidn2 is a package designed for internationalized string handling based on standards from the Internet Engineering Task Force (IETF)'s IDN working group,designed for internationalized domain names."
url="https://ftp.gnu.org/gnu/libidn2"
archs=("armeabi-v7a" "arm64-v8a")
license=("lgpl-2.0")
depends=()
makedepends=()

source="https://ftp.gnu.org/gnu/libidn/${pkgname}-${pkgver}.tar.gz"

downloadpackage=true
autounpack=true
buildtools="configure"

builddir=$pkgname-${pkgver}
packagename=$builddir.tar.gz

source envset.sh
host=

prepare() {
    mkdir -p $builddir/$ARCH-build
    if [ $ARCH == "armeabi-v7a" ]
    then
        setarm32ENV
        host=arm-linux
    elif [ $ARCH == "arm64-v8a" ]
    then
        setarm64ENV
        host=aarch64-linux
    else
        return -1
    fi

    return 0
}

build() {
    cd $builddir/$ARCH-build
    ../configure "$@" --host=$host > $buildlog 2>&1
    $MAKE >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir/$ARCH-build
    $MAKE install >> $buildlog 2>&1
    cd $OLDPWD
    unset host
}

check() {
    if [ $ARCH == "armeabi-v7a" ]
    then
        unsetarm32ENV
    elif [ $ARCH == "arm64-v8a" ]
    then
        unsetarm64ENV
    else
        return -1
    fi

    echo "The test must be on an OpenHarmony device!"
    return 0
}

# 清理环境
cleanbuild(){
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
}
